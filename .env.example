# Auth0
AUTH0_SECRET=           # Run: openssl rand -hex 32
AUTH0_BASE_URL=http://localhost:3001
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://guardian-agent.local/api

# OpenAI (for Guardian Agent AI)
OPENAI_API_KEY=sk-...

# Feature flags
USE_MOCK_TOKENS=true    # Set to "false" to use real Token Vault tokens
